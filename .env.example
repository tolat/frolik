# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development          # "development" or "production"
PORT=3001                     # Port the Express server listens on
SERVER=http://localhost:3001  # Full URL of the server (used in CORS + email links)
SECRET=change-me-to-a-long-random-string
SESSION_DURATION=604800000    # Session length in milliseconds (604800000 = 7 days)

# ── Database ──────────────────────────────────────────────────────────────────
# Local MongoDB:  mongodb://localhost:27017/frolik
# MongoDB Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/frolik
DB_URL=mongodb://localhost:27017/frolik

# ── AWS S3 (image storage) ────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_BUCKET=your-s3-bucket-name

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
# SENDMAIL_FROM_PASSWORD must be a Gmail App Password, NOT your regular password.
# Generate one at: https://myaccount.google.com/apppasswords
SENDMAIL_FROM=your-email@gmail.com
SENDMAIL_FROM_PASSWORD=your-gmail-app-password

# ── Web Push Notifications (VAPID) ────────────────────────────────────────────
# Generate keys by running: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ── Seeding (optional) ────────────────────────────────────────────────────────
# Set ALLOW_SEED=true to allow `npm run seed` to populate the database.
# WARNING: never set SEED_PRODUCTION=true unless you want to wipe your S3 bucket.
ALLOW_SEED=true
# SEED_PRODUCTION=true
